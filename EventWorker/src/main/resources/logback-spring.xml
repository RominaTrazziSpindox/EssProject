<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProperty scope="context"
                    name="appName"
                    source="spring.application.name"/>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %yellow([${appName}]) %highlight(%-5level) %cyan(%logger{36}) - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Spring framework -->
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>

    <!-- Only code in DEBUG mode -->
    <logger name="com.spx" level="DEBUG"/>

</configuration>
